{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kaorii",
  "version": "1.1.0",
  "identifier": "com.nonseww.Kaorii",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kaorii",
        "width": 70,
        "height": 70,
        "minWidth": 70,
        "minHeight": 70,
        "maxWidth": 70,
        "maxHeight": 70,
        "shadow": false,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/llama-server"]
  }
}
